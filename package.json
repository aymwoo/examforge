{
  "name": "examforge-root",
  "version": "1.0.0",
  "private": true,
  "description": "ExamForge Monorepo - AI-driven question bank and examination system",
  "scripts": {
    "build": "pnpm --filter ./packages --filter ./apps --filter ./web run build",
    "build:api": "pnpm --filter ./apps/api build",
    "build:web": "pnpm --filter ./web build",
    "dev": "pnpm --parallel --filter ./apps/api --filter ./web run dev",
    "dev:api": "cd apps/api && pnpm start:dev",
    "dev:web": "pnpm --filter ./web dev",
    "lint": "pnpm --filter ./packages --filter ./apps --filter ./web run lint",
    "lint:fix": "pnpm --filter ./packages --filter ./apps --filter ./web run lint:fix",
    "test": "pnpm --filter ./packages --filter ./apps --filter ./web run test",
    "test:e2e": "pnpm --filter @examforge/api test:e2e",
    "clean": "pnpm --filter './**' run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.18.2"
}
