// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String
  role      String   @default("STUDENT") // ADMIN, TEACHER, STUDENT
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // е…іиҒ”е…ізі»
  createdQuestions Question[] @relation("CreatedBy")
  createdExams     Exam[]     @relation("CreatedBy")
  createdClasses   Class[]    @relation("CreatedClasses")
  aiProviders      AIProvider[] @relation("CreatedAIProviders")
  userSettings     UserSetting[]
  importRecords    ImportRecord[] @relation("ImportRecords")

  @@map("users")
}

model AIProvider {
  id          String   @id @default(cuid())
  name        String
  apiKey      String
  baseUrl     String?
  model       String
  isGlobal    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // е…іиҒ”е…ізі»
  creator User? @relation("CreatedAIProviders", fields: [createdBy], references: [id])

  @@map("ai_providers")
}

model Question {
  id             String   @id @default(cuid())
  content        String
  type           String
  options        String?
  answer         String?
  explanation    String?
  illustration   String?  // еӣҫдҫӢеӯ—ж®өпјҢеӯҳеӮЁеӣҫзүҮURLжҲ–base64
  images         String?  @default("[]") // JSON array of image paths
  tags           String
  difficulty     Int      @default(1)
  status         String   @default("DRAFT")
  knowledgePoint String?
  isPublic       Boolean  @default(true) @map("is_public") // жҳҜеҗҰе…¬ејҖ
  importOrder    Int?     @map("import_order") // еҜје…Ҙж—¶зҡ„йЎәеәҸ
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // е…іиҒ”е…ізі»
  creator       User?          @relation("CreatedBy", fields: [createdBy], references: [id])
  examQuestions ExamQuestion[]

  @@map("questions")
}

model Exam {
  id          String   @id @default(cuid())
  title       String
  description String?
  duration    Int
  totalScore  Int      @default(100)
  status      String   @default("DRAFT")
  accountModes String  @default("[\"TEMPORARY_IMPORT\"]") @map("account_modes") // JSON array of enabled modes
  startTime   DateTime?
  endTime     DateTime?
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // AIеҲҶжһҗжҠҘе‘ҠпјҲиҖғиҜ•ж•ҙдҪ“пјү
  aiAnalysisReport     String?   @map("ai_analysis_report")
  aiAnalysisStatus     String?   @map("ai_analysis_status")
  aiAnalysisPromptUsed String?   @map("ai_analysis_prompt_used")
  aiAnalysisProviderId String?   @map("ai_analysis_provider_id")
  aiAnalysisModel      String?   @map("ai_analysis_model")
  aiAnalysisUpdatedAt  DateTime? @map("ai_analysis_updated_at")

  // е…іиҒ”е…ізі»
  creator       User?          @relation("CreatedBy", fields: [createdBy], references: [id])
  examQuestions ExamQuestion[]
  submissions   Submission[]
  examStudents  ExamStudent[]

  @@map("exams")
}

model ExamQuestion {
  id         String   @id @default(cuid())
  examId     String
  questionId String
  order      Int
  score      Int      @default(1)

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
  @@index([examId])
  @@index([questionId])
  @@map("exam_questions")
}

model Submission {
  id                 String    @id @default(cuid())
  examId             String
  examStudentId      String?   @map("exam_student_id")
  answers            String
  score              Float?
  isAutoGraded       Boolean   @default(false)
  isReviewed         Boolean   @default(false) // ж•ҷеёҲжҳҜеҗҰе·ІеӨҚж ё
  reviewedBy         String?   @map("reviewed_by") // еӨҚж ёж•ҷеёҲID
  reviewedAt         DateTime? @map("reviewed_at") // еӨҚж ёж—¶й—ҙ
  gradingDetails     String?   @map("grading_details") // JSONж јејҸеӯҳеӮЁиҜҰз»ҶиҜ„еҲҶдҝЎжҒҜ
  aiAnalysisReport   String?   @map("ai_analysis_report")
  aiAnalysisUpdatedAt DateTime? @map("ai_analysis_updated_at")
  aiAnalysisStatus   String?   @map("ai_analysis_status")
  aiAnalysisPromptUsed String? @map("ai_analysis_prompt_used")
  aiAnalysisProvider String?   @map("ai_analysis_provider")
  aiAnalysisModel    String?   @map("ai_analysis_model")
  submittedAt        DateTime  @default(now()) @map("submitted_at")

  exam        Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  examStudent ExamStudent? @relation(fields: [examStudentId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@map("submissions")
}

model ExamStudent {
  id          String   @id @default(cuid())
  examId      String   @map("exam_id")
  username    String
  password    String
  displayName String?  @map("display_name")
  accountType String   @default("TEMPORARY") @map("account_type") // PERMANENT | TEMPORARY
  studentId   String?  @map("student_id") // е…іиҒ”еӣәе®ҡеӯҰз”ҹзҡ„еӯҰеҸ·
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  exam        Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     Student?     @relation(fields: [studentId], references: [studentId])
  submissions Submission[]
  aiAnalysisReports StudentAiAnalysisReport[]

  @@unique([examId, username])
  @@map("exam_students")
}

model Student {
  id               String   @id @default(cuid())
  studentId        String   @unique @map("student_id") // еӯҰеҸ·
  name             String
  gender           String?  // жҖ§еҲ«
  classId          String?  @map("class_id")
  password         String
  aiAnalysisPrompt String?  @map("ai_analysis_prompt")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  class        Class?       @relation(fields: [classId], references: [id])
  examStudents ExamStudent[]

  @@map("students")
}

model Class {
  id          String   @id @default(cuid())
  name        String   // зҸӯзә§еҗҚз§°
  code        String   @unique // зҸӯзә§д»Јз Ғ
  description String?  // зҸӯзә§жҸҸиҝ°
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator   User?     @relation("CreatedClasses", fields: [createdBy], references: [id])
  students  Student[]

  @@map("classes")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  key       String
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // е…іиҒ”е…ізі»
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("user_settings")
}

model StudentAiAnalysisReport {
  id           String   @id @default(cuid())
  submissionId String   @unique @map("submission_id")
  examId       String   @map("exam_id")
  examStudentId String? @map("exam_student_id")
  studentId    String?  @map("student_id")

  status       String   @default("PENDING")
  progress     Int      @default(0)
  providerId   String?  @map("provider_id")
  model        String?
  promptUsed   String?  @map("prompt_used")
  report       String?
  errorMessage String?  @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // е…іиҒ”е…ізі»
  examStudent ExamStudent? @relation(fields: [examStudentId], references: [id])

  @@index([examId, examStudentId])
  @@index([studentId])
  @@map("student_ai_analysis_reports")
}

model ImportRecord {
  id          String    @id @default(cuid())
  jobId       String    @unique @map("job_id")
  fileName    String    @map("file_name")
  fileSize    Int       @map("file_size")
  filePath    String?   @map("file_path")
  userId      String?   @map("user_id")
  mode        String    @default("vision")
  status      String    @default("processing")
  questionIds String    @default("[]") @map("question_ids") // JSON array
  errorMessage String?  @map("error_message")
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  // е…іиҒ”е…ізі»
  user User? @relation("ImportRecords", fields: [userId], references: [id])

  @@map("import_records")
}
