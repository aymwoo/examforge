# Multi-stage build for ExamForge Web Frontend

# Stage 1: Build dependencies
FROM node:18-alpine AS deps
WORKDIR /app

# Optimize for China
RUN sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories

# Install pnpm via corepack and configure mirror
ENV NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
RUN corepack enable && \
    pnpm config set registry https://registry.npmmirror.com

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install all dependencies
RUN pnpm install --frozen-lockfile --prod=false

# Stage 2: Build the application
FROM node:18-alpine AS builder
WORKDIR /app

# Optimize for China
RUN sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories

# Copy pnpm store from previous stage
COPY --from=deps /root/.pnpm-store /root/.pnpm-store

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install pnpm via corepack and configure mirror
ENV NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
RUN corepack enable && \
    pnpm config set registry https://registry.npmmirror.com

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Build the web application
RUN pnpm --filter @examforge/web build

# Stage 3: Production runtime with nginx
FROM nginx:alpine AS runtime

# Optimize for China
RUN sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories

# Copy nginx configuration
COPY docker/nginx.conf /etc/nginx/nginx.conf

# Copy built application from builder stage
COPY --from=builder /app/web/dist /usr/share/nginx/html

# Expose port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost || exit 1

# Start nginx
CMD ["nginx", "-g", "daemon off;"]