# Multi-stage build for ExamForge Web Frontend

# Stage 1: Build dependencies
FROM node:18-alpine AS deps
WORKDIR /app

ARG APK_MIRROR
ARG NPM_REGISTRY=https://registry.npmjs.org

# Optional: optimize for CN mirrors
RUN if [ -n "$APK_MIRROR" ]; then \
      sed -i "s/dl-cdn.alpinelinux.org/$APK_MIRROR/g" /etc/apk/repositories; \
    fi

# Install pnpm globally with mirror
ENV NPM_CONFIG_REGISTRY=$NPM_REGISTRY
RUN npm config set registry $NPM_REGISTRY && \
    npm install -g pnpm@10.28.0 && \
    pnpm config set registry $NPM_REGISTRY

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install dependencies (to create pnpm store)
RUN pnpm install --frozen-lockfile --prod=false

# Export pnpm store path for next stage
RUN pnpm store path --silent > /tmp/pnpm-store-path

# Stage 2: Build the application
FROM node:18-alpine AS builder
WORKDIR /app

ARG APK_MIRROR
ARG NPM_REGISTRY=https://registry.npmjs.org

# Optional: optimize for CN mirrors
RUN if [ -n "$APK_MIRROR" ]; then \
      sed -i "s/dl-cdn.alpinelinux.org/$APK_MIRROR/g" /etc/apk/repositories; \
    fi

# Copy pnpm store from previous stage
COPY --from=deps /tmp/pnpm-store-path /tmp/pnpm-store-path
RUN PNPM_STORE_PATH=$(cat /tmp/pnpm-store-path) && \
    mkdir -p "$PNPM_STORE_PATH"
COPY --from=deps /root/.pnpm-store /root/.pnpm-store

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install pnpm globally with mirror
ENV NPM_CONFIG_REGISTRY=$NPM_REGISTRY
RUN npm config set registry $NPM_REGISTRY && \
    npm install -g pnpm@10.28.0 && \
    pnpm config set registry $NPM_REGISTRY

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Build the web application
RUN pnpm --filter @examforge/web build

# Stage 3: Production runtime with nginx
FROM nginx:alpine AS runtime

ARG APK_MIRROR

# Optional: optimize for CN mirrors
RUN if [ -n "$APK_MIRROR" ]; then \
      sed -i "s/dl-cdn.alpinelinux.org/$APK_MIRROR/g" /etc/apk/repositories; \
    fi

# Copy nginx configuration
COPY docker/nginx.conf /etc/nginx/nginx.conf

# Copy built application from builder stage
COPY --from=builder /app/web/dist /usr/share/nginx/html

# Expose port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost || exit 1

# Start nginx
CMD ["nginx", "-g", "daemon off;"]